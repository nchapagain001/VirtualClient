{
    "Description": "Installs Docker Engine on Linux systems for container-based workloads.",
    "Metadata": {
        "RecommendedMinimumExecutionTime": "00:05:00",
        "SupportedPlatforms": "linux-x64,linux-arm64",
        "SupportedOperatingSystems": "Ubuntu"
    },
    "Parameters": {
        "DockerVersion": ""
    },
  "Dependencies": [
    {
      "Type": "DockerInstallation",
      "Parameters": {
        "Scenario": "InstallDocker",
        "Version": "$.Parameters.DockerVersion"
      }
    },
    {
      "Type": "ExecuteCommand",
      "Parameters": {
        "Scenario": "AddUserToDockerGroup",
        "Command": "sudo usermod -aG docker $(whoami)"
      }
    },
    {
      "Type": "ExecuteCommand",
      "Parameters": {
        "Scenario": "StartDocker",
        "Command": "sudo systemctl start docker"
      }
    },
    {
      "Type": "ExecuteCommand",
      "Parameters": {
        "Scenario": "EnableDocker",
        "Command": "sudo systemctl enable docker"
      }
    },
    {
      "Type": "ExecuteCommand",
      "Parameters": {
        "Scenario": "VerifyDockerSetup",
        "Command": "sudo docker version"
      }
    }
  ]
}
